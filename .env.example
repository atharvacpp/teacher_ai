# ---------------------------------------------------
# Environment Variables for Teacher AI
# Copy this file to .env and fill in your API keys.
# ---------------------------------------------------

# HuggingFace API Key (Required)
# Used for Qwen 2.5 7B chat model via serverless inference.
# Get yours at: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your-huggingface-api-key-here

# Groq API Key (Required for Pipeline C — Generate Lesson)
# Powers Llama 3.1 8B (router) & Llama 3.3 70B (teacher agent).
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# Ollama Base URL (Required)
# Points to your local Ollama instance for DeepSeek Coder & LLaVA models.
OLLAMA_BASE_URL=http://localhost:11434

# Pinecone API Key (Optional — for Self-RAG vector retrieval in Pipeline C)
# If not set, Pipeline C will fall back to web search for grounding.
# Get yours at: https://app.pinecone.io/
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_INDEX_NAME=teacher-ai
