# =============================================================================
# .gitignore — Multimodal AI Explainer Platform
# =============================================================================

# ---------- Environment & Secrets ----------
.env
.env.*
!.env.example

# ---------- Python Backend ----------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/
ENV/
.mypy_cache/
.ruff_cache/
.pytest_cache/

# ---------- Node Frontend ----------
node_modules/
frontend/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
frontend/dist/
frontend/dist-ssr/
*.local

# ---------- Ollama / Model Caches ----------
*.gguf
*.bin
models/

# ---------- Temporary Media / Uploads ----------
*.webm
*.wav
*.mp3
*.ogg
*.flac
*.m4a
*.mp4
*.mov
*.avi
recordings/
temp_audio/

# ---------- Local Debug & Logs ----------
sandbox/__pycache__/
sandbox/smoke_test.py
debug/
scratch/
_test_*.py
test.pdf
*.log
*.bak
*.tmp

# ---------- OS & IDE Files ----------
.DS_Store
Thumbs.db
Desktop.ini
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.gemini/
